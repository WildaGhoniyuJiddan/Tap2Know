rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{username} {
      // Anyone can view the profile for the public taptoknow.id link
      allow read: if true;
      
      // Only the logged-in owner (using the Custom Token with uid == username) can edit
      allow write: if request.auth != null && request.auth.uid == username;
    }
  }
}
